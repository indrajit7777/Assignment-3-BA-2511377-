# ======Part A: Safe Divide =======
def safe_divide(a, b):
    try:
        return a / b
    except ZeroDivisionError:
        return "Error: Cannot divide by zero"
    except TypeError:
        return "Error: Invalid input types"


print("=== Part A: Guarded Calculator ===")
print(safe_divide(10, 2))
print(safe_divide(10, 0))
print(safe_divide("ten", 2))
print()


# ===== Part B: Safe File Reader ====
def read_file_safe(filename):
    try:
        f = open(filename, "r", encoding="utf-8")
        content = f.read()
        f.close()
        return content
    except FileNotFoundError:
        print(f"Error: File '{filename}' not found.")
        return None
    finally:
        print("File operation attempt complete.")


print("=== Part B: Guarded File Reader ===")
content = read_file_safe("python_notes.txt")
if content:
    print("First line:", content.split("\n")[0])

read_file_safe("ghost_file.txt")
print()


# ===== Part C: Robust API Calls=====
def safe_get(url):
    try:
        r = requests.get(url, timeout=5)
        return r
    except requests.exceptions.ConnectionError:
        print("Connection failed. Please check your internet.")
        return None
    except requests.exceptions.Timeout:
        print("Request timed out. Try again later.")
        return None
    except Exception as e:
        print("Error:", e)
        return None


print("=== Part C: Robust API Calls ===")
resp = safe_get("https://dummyjson.com/products?limit=3")
if resp and resp.status_code == 200:
    print("API call successful!")
print()


# ==== Part D: Input Validation Loop ======
print("=== Part D: Product Lookup ===")

while True:
    user = input("Enter a product ID (1-100) or 'quit': ").strip()
    
    if user.lower() == "quit":
        print("Goodbye!")
        break
    
    try:
        pid = int(user)
        if pid < 1 or pid > 100:
            print("Please enter number between 1 and 100")
            continue
    except:
        print("Please enter a valid number")
        continue
    
    # Make API call
    url = f"https://dummyjson.com/products/{pid}"
    resp = safe_get(url)
    
    if resp:
        if resp.status_code == 200:
            p = resp.json()
            print(f"Found: {p['title']} - ${p['price']}")
        elif resp.status_code == 404:
            print("Product not found.")
