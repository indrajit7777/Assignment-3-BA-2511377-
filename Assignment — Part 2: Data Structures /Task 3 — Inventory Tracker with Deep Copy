# Original inventory
inventory = {
    "Paneer Tikka": {"stock": 10, "reorder_level": 3},
    "Chicken Wings": {"stock": 8, "reorder_level": 2},
    "Veg Soup": {"stock": 15, "reorder_level": 5},
    "Butter Chicken": {"stock": 12, "reorder_level": 4},
    "Dal Tadka": {"stock": 20, "reorder_level": 5},
    "Veg Biryani": {"stock": 6, "reorder_level": 3},
    "Garlic Naan": {"stock": 30, "reorder_level": 10},
    "Gulab Jamun": {"stock": 5, "reorder_level": 2},
    "Rasgulla": {"stock": 4, "reorder_level": 3},
    "Ice Cream": {"stock": 7, "reorder_level": 4},
}

# Part 1: Deep Copy
inventory_backup = copy.deepcopy(inventory)

# Test if deep copy works
inventory["Paneer Tikka"]["stock"] = 999

print("After changing stock in original inventory:")
print("Current inventory - Paneer Tikka stock:", inventory["Paneer Tikka"]["stock"])
print("Backup inventory - Paneer Tikka stock:", inventory_backup["Paneer Tikka"]["stock"])
print("Deepcopy worked! Backup remained unchanged.\n")

# Restore original stock
inventory["Paneer Tikka"]["stock"] = 10
print("Restored Paneer Tikka stock back to 10.\n")

# Part 2: Order Fulfilment
final_cart = [{"item": "Paneer Tikka", "quantity": 3, "price": 180.0}]

print("--- Order Fulfilment ---")
for order in final_cart:
    name = order["item"]
    qty = order["quantity"]
    
    if name in inventory:
        stock = inventory[name]["stock"]
        if stock >= qty:
            inventory[name]["stock"] = stock - qty
            print(f"Deducted {qty} from {name}")
            print(f"Stock left for {name}: {inventory[name]['stock']}")
        else:
            print(f"Warning: Not enough stock for {name}")
            print(f"Needed {qty}, but only {stock} available")
            inventory[name]["stock"] = 0
            print(f"Stock for {name} set to 0")
    else:
        print(f"Error: {name} not found in inventory")
print()

# Part 3: Reorder Alerts
print("--- Reorder Alerts ---")
for item in inventory:
    stock = inventory[item]["stock"]
    reorder = inventory[item]["reorder_level"]
    if stock <= reorder:
        print(f"Reorder Alert: {item} - Only {stock} left (Reorder level: {reorder})")
print()

# Part 4: Final Comparison
print("--- Final Comparison (inventory vs backup) ---")
print(f"Paneer Tikka - Current stock : {inventory['Paneer Tikka']['stock']}")
print(f"Paneer Tikka - Backup stock  : {inventory_backup['Paneer Tikka']['stock']}")
print("Deep copy successfully protected the original data!")
